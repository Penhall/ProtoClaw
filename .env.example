# ProtoClaw — Environment Variables
# At least one LLM provider is required.
# Ollama (free, local) is always the last fallback if running locally.

ANTHROPIC_API_KEY=        # primary: claude-opus-4-6
OPENAI_API_KEY=           # fallback: gpt-4o

# Google AI (Gemini)
GOOGLE_AI_API_KEY=AIzaSyBYqjxnw_RgRT_xoCGX2yaW4tnms7b2P7w
GOOGLE_AI_MODEL=gemini-3.1-flash
GOOGLE_AI_TEMPERATURE=0.4
GOOGLE_AI_MAX_TOKENS=200



OLLAMA_MODEL=llama3       # last resort (ollama must be running at localhost:11434)

# Docker network name for deployed agents
PROTOCLAW_NETWORK=protoclaw-net

# Override default model for generated agent configs
# PROTOCLAW_MODEL=claude-opus-4-6
